                        },
                        {
                            "rule": "product_id_ref_check",
                            "column": "product_id",
                            "status": "failed",
                            "nullRate": null,
                            "failRate": 0.011,
                            "message": "1.1% of product_ids have no match in products table"
                        },
                        {
                            "rule": "stock_level_not_null",
                            "column": "stock_level",
                            "status": "passed",
                            "nullRate": 0.0,
                            "failRate": null,
                            "message": null
                        }
                    ]
                }
            },
            "slo": {
                "uptime": {
                    "objectivePct": 99.5,
                    "actualPct": 99.9,
